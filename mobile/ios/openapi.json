{
  "openapi": "3.1.0",
  "info": {
    "title": "TokenFuse Cloud",
    "description": "Fleet-wide control plane: per-org spend, kill-switch and central budgets.",
    "license": {
      "name": "Apache-2.0",
      "identifier": "Apache-2.0"
    },
    "version": "0.0.1"
  },
  "paths": {
    "/v1/alerts": {
      "get": {
        "tags": [
          "reads"
        ],
        "summary": "Runs at or above the alert threshold of their central budget.",
        "operationId": "alerts",
        "parameters": [
          {
            "name": "pct",
            "in": "query",
            "description": "Budget fraction (0..1) to flag at; defaults to the server's `alert_pct`.",
            "required": false,
            "schema": {
              "type": [
                "number",
                "null"
              ],
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "runs near or over budget",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Alert"
                  }
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/budgets": {
      "get": {
        "tags": [
          "mutations"
        ],
        "summary": "This org's run → budget-micros overrides (gateways poll this).",
        "operationId": "budgets",
        "responses": {
          "200": {
            "description": "run → budget micros"
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/devices/{id}/activity": {
      "post": {
        "tags": [
          "devices"
        ],
        "summary": "Register a Live Activity push token for a run (device-signed).",
        "operationId": "register_activity",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "device id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ActivityBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "activity registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "403": {
            "description": "signature invalid / not this device",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/devices/{id}/apns": {
      "post": {
        "tags": [
          "devices"
        ],
        "summary": "Register/refresh a device's APNs token (device-signed; `{id}` must be the\nsigning device).",
        "operationId": "register_apns",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "device id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ApnsBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "token registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/OkResponse"
                }
              }
            }
          },
          "403": {
            "description": "signature invalid / not this device",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "404": {
            "description": "unknown device",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/ingest": {
      "post": {
        "tags": [
          "telemetry"
        ],
        "summary": "A gateway pushes a batch of settled calls for its org.",
        "operationId": "ingest",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/IngestBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "records accepted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/IngestResponse"
                }
              }
            }
          },
          "400": {
            "description": "malformed json",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/kills": {
      "get": {
        "tags": [
          "mutations"
        ],
        "summary": "Run ids this org has killed (gateways poll this).",
        "operationId": "kills",
        "responses": {
          "200": {
            "description": "killed run ids",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pair": {
      "post": {
        "tags": [
          "pairing"
        ],
        "summary": "Redeem a pairing code with a device public key. No bearer auth — the code is\nthe credential. Returns the device's identity and its read token.",
        "operationId": "pair",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PairRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "device registered",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PairResponse"
                }
              }
            }
          },
          "400": {
            "description": "invalid or expired code / bad json",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/pair/new": {
      "post": {
        "tags": [
          "pairing"
        ],
        "summary": "Issue a one-time pairing code (admin org key). The dashboard renders it as a\nQR the app scans.",
        "operationId": "pair_new",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PairNewBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "pairing code (valid 10 min)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PairNewResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "admin role required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs": {
      "get": {
        "tags": [
          "reads"
        ],
        "summary": "The caller org's aggregated runs.",
        "operationId": "runs",
        "responses": {
          "200": {
            "description": "aggregated runs",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RunAgg"
                  }
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs/{run}/budget": {
      "post": {
        "tags": [
          "mutations"
        ],
        "summary": "Set a central budget for a run (admin only). Gateways poll `/v1/budgets`.",
        "operationId": "set_budget",
        "parameters": [
          {
            "name": "run",
            "in": "path",
            "description": "run id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BudgetBody"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "budget set",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BudgetResponse"
                }
              }
            }
          },
          "400": {
            "description": "malformed json",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "admin role required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/runs/{run}/kill": {
      "post": {
        "tags": [
          "mutations"
        ],
        "summary": "Mark a run killed (admin only). Gateways poll `/v1/kills` and hard-stop it.",
        "operationId": "kill",
        "parameters": [
          {
            "name": "run",
            "in": "path",
            "description": "run id",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "run killed",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/KillResponse"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "403": {
            "description": "admin role required",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/series": {
      "get": {
        "tags": [
          "reads"
        ],
        "summary": "Burn-rate buckets over a time window — feeds the chart and the Dynamic Island.",
        "operationId": "series",
        "parameters": [
          {
            "name": "run",
            "in": "query",
            "description": "Scope to a single run; omit for the whole org.",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "window",
            "in": "query",
            "description": "Time span back from now, e.g. `1h`, `24h`, `30m` (default `1h`).",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          {
            "name": "step",
            "in": "query",
            "description": "Bucket width, e.g. `60s`, `5m` (default `60s`).",
            "required": false,
            "schema": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "time buckets, oldest first",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/SeriesBucket"
                  }
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    },
    "/v1/summary": {
      "get": {
        "tags": [
          "reads"
        ],
        "summary": "Org-wide totals.",
        "operationId": "summary",
        "responses": {
          "200": {
            "description": "org totals",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Summary"
                }
              }
            }
          },
          "401": {
            "description": "unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "ActivityBody": {
        "type": "object",
        "required": [
          "activity_token",
          "run_id"
        ],
        "properties": {
          "activity_token": {
            "type": "string",
            "description": "ActivityKit push-to-update token."
          },
          "run_id": {
            "type": "string",
            "description": "The run this Live Activity tracks."
          }
        }
      },
      "Alert": {
        "type": "object",
        "description": "A run that has spent at or above a fraction of its central budget.",
        "required": [
          "run_id",
          "spent_microusd",
          "budget_micros",
          "fraction",
          "killed"
        ],
        "properties": {
          "budget_micros": {
            "type": "integer",
            "format": "int64"
          },
          "fraction": {
            "type": "number",
            "format": "double"
          },
          "killed": {
            "type": "boolean"
          },
          "run_id": {
            "type": "string"
          },
          "spent_microusd": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ApnsBody": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string",
            "description": "APNs device token (hex) for push delivery."
          }
        }
      },
      "BudgetBody": {
        "type": "object",
        "required": [
          "budget_usd"
        ],
        "properties": {
          "budget_usd": {
            "type": "number",
            "format": "double"
          }
        }
      },
      "BudgetResponse": {
        "type": "object",
        "required": [
          "run",
          "budget_micros"
        ],
        "properties": {
          "budget_micros": {
            "type": "integer",
            "format": "int64"
          },
          "run": {
            "type": "string"
          }
        }
      },
      "CallRecord": {
        "type": "object",
        "description": "One settled call, pushed by a gateway's `CloudSink`. The wire shape matches\n`crates/gateway/src/sink.rs::CallRecord` (kept in sync by hand, exactly as\nthe Go plane did); a later cleanup can hoist the shared type into\n`tokenfuse-core` so producer and consumer derive it from one definition.",
        "required": [
          "run_id"
        ],
        "properties": {
          "cost_microusd": {
            "type": "integer",
            "format": "int64"
          },
          "decision": {
            "type": "string"
          },
          "input_tokens": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "model": {
            "type": "string"
          },
          "output_tokens": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "run_id": {
            "type": "string"
          },
          "step": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          },
          "ts_millis": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": [
          "error"
        ],
        "properties": {
          "error": {
            "type": "string"
          }
        }
      },
      "IngestBody": {
        "type": "object",
        "properties": {
          "records": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CallRecord"
            }
          }
        }
      },
      "IngestResponse": {
        "type": "object",
        "required": [
          "accepted"
        ],
        "properties": {
          "accepted": {
            "type": "integer",
            "minimum": 0
          }
        }
      },
      "KillResponse": {
        "type": "object",
        "required": [
          "killed"
        ],
        "properties": {
          "killed": {
            "type": "string"
          }
        }
      },
      "OkResponse": {
        "type": "object",
        "required": [
          "ok"
        ],
        "properties": {
          "ok": {
            "type": "boolean"
          }
        }
      },
      "PairNewBody": {
        "type": "object",
        "properties": {
          "role": {
            "type": [
              "string",
              "null"
            ],
            "description": "Role the paired device will have (`admin` | `viewer`); default `admin`."
          }
        }
      },
      "PairNewResponse": {
        "type": "object",
        "required": [
          "code",
          "expires_unix"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "expires_unix": {
            "type": "integer",
            "format": "int64"
          }
        }
      },
      "PairRequest": {
        "type": "object",
        "required": [
          "code",
          "pubkey_b64"
        ],
        "properties": {
          "code": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          },
          "pubkey_b64": {
            "type": "string",
            "description": "Device public key, base64 SEC1/X9.63."
          }
        }
      },
      "PairResponse": {
        "type": "object",
        "required": [
          "device_id",
          "org",
          "role",
          "device_token"
        ],
        "properties": {
          "device_id": {
            "type": "string"
          },
          "device_token": {
            "type": "string"
          },
          "org": {
            "type": "string"
          },
          "role": {
            "type": "string"
          }
        }
      },
      "RunAgg": {
        "type": "object",
        "description": "The aggregated state of one run within an organization.",
        "required": [
          "run_id",
          "model",
          "spent_microusd",
          "calls",
          "cache_hits",
          "steps",
          "last_seen_millis",
          "killed"
        ],
        "properties": {
          "cache_hits": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "calls": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "killed": {
            "type": "boolean"
          },
          "last_seen_millis": {
            "type": "integer",
            "format": "int64"
          },
          "model": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "spent_microusd": {
            "type": "integer",
            "format": "int64"
          },
          "steps": {
            "type": "integer",
            "format": "int32",
            "minimum": 0
          }
        }
      },
      "SeriesBucket": {
        "type": "object",
        "description": "One time bucket of the burn-rate series.",
        "required": [
          "t",
          "cost_microusd",
          "calls",
          "blocked"
        ],
        "properties": {
          "blocked": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "calls": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "cost_microusd": {
            "type": "integer",
            "format": "int64"
          },
          "t": {
            "type": "integer",
            "format": "int64",
            "description": "Bucket start, epoch millis."
          }
        }
      },
      "Summary": {
        "type": "object",
        "description": "Org-wide totals.",
        "required": [
          "runs",
          "calls",
          "spent_microusd"
        ],
        "properties": {
          "calls": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "runs": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "spent_microusd": {
            "type": "integer",
            "format": "int64"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "telemetry",
      "description": "Ingest of gateway call records"
    },
    {
      "name": "reads",
      "description": "Aggregated per-org views"
    },
    {
      "name": "mutations",
      "description": "Operator actions (admin only)"
    },
    {
      "name": "pairing",
      "description": "Device pairing + Enclave-signed auth"
    },
    {
      "name": "devices",
      "description": "Per-device push registration (signed)"
    }
  ]
}
